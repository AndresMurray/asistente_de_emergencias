# Configuración del servidor de Pipelines de Open WebUI
# Las variables aquí están disponibles para todos los pipelines cargados

# URI de conexión a la base de datos vectorial (pgvector)
DATABASE_URL=postgresql://postgres:postgres@vdb:5432/emergencias_vdb

# URL del servicio de Ollama
OLLAMA_URL=http://ollama:11434

# Modelo LLM por defecto
MODEL_NAME=llama3:8b
