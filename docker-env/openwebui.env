# Configuración de Open WebUI
# Conexión con el servicio de Ollama (nombre del servicio en docker-compose)
OLLAMA_BASE_URL=http://ollama:11434

# Conexión con el servidor de Pipelines (se registra como endpoint OpenAI-compatible)
OPENAI_API_BASE_URLS=http://pipelines:9099
OPENAI_API_KEYS=0p3n-w3bu!

# Deshabilitar registro público (solo admin puede crear cuentas luego del primero)
WEBUI_AUTH=true
